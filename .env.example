# ExamPass app build — .env is now OPTIONAL.
#
# The directory base URL is baked into the app (src/api/osim/directoryConfig.ts)
# and per-tenant connection details are served from the directory at runtime, so
# a normal build needs NO .env at all. The variables below are dev overrides:
#
#   EXPO_PUBLIC_DIRECTORY_URL    point a dev build at a staging directory
#   EXPO_PUBLIC_DIRECTORY_TOKEN  app token, once the directory requires auth
#                                (DIRECTORY_REQUIRE_AUTH=true on the server)
#
# Leave them blank/absent for the production directory.
EXPO_PUBLIC_DIRECTORY_URL=
EXPO_PUBLIC_DIRECTORY_TOKEN=
