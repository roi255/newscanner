# Copy to .env (gitignored) for local live-scan testing.
# One key per OSIM tenant (src/data/institutions.ts). Leave blank to keep a
# tenant inert (listed in the picker, but no live scanning). Generate each key
# from that tenant's OSIM admin (cis_sys_api_app) and paste it here.
EXPO_PUBLIC_STEMMUCO_DEV_KEY=
EXPO_PUBLIC_MAKUMIRA_DEV_KEY=
EXPO_PUBLIC_AJUCO_DEV_KEY=
EXPO_PUBLIC_AMUCTA_DEV_KEY=
EXPO_PUBLIC_BUGANDO_DEV_KEY=
EXPO_PUBLIC_CARUMUCO_DEV_KEY=
EXPO_PUBLIC_CHATOCOHEST_DEV_KEY=
EXPO_PUBLIC_DARTU_DEV_KEY=
EXPO_PUBLIC_FHTI_DEV_KEY=
EXPO_PUBLIC_HKMU_DEV_KEY=
EXPO_PUBLIC_KIAHS_DEV_KEY=
EXPO_PUBLIC_KIUT_DEV_KEY=
EXPO_PUBLIC_KSP_DEV_KEY=
EXPO_PUBLIC_LIHAS_DEV_KEY=
EXPO_PUBLIC_MTI_DEV_KEY=
EXPO_PUBLIC_RHTI_DEV_KEY=
EXPO_PUBLIC_SAUT_DEV_KEY=
EXPO_PUBLIC_SMMUCO_DEV_KEY=
EXPO_PUBLIC_SOCAITE_DEV_KEY=
EXPO_PUBLIC_STC_DEV_KEY=
EXPO_PUBLIC_SUMAIT_DEV_KEY=
EXPO_PUBLIC_TUDARCO_DEV_KEY=
EXPO_PUBLIC_UOA_DEV_KEY=
EXPO_PUBLIC_WIARC_DEV_KEY=

# Central directory API base URL (e.g. https://registry.campusmaster.cloud). Blank => bundled list.
